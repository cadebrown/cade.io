---
import type { ImageMetadata } from 'astro'
import Image from './Image.astro'

type Props = {
    images: (string | ImageMetadata)[]
    alt: string
}

const { images, alt } = Astro.props
---

<ol class='gallery-list'>
    {
        images.map(
            (image, index) =>
                image && (
                    <li class='gallery-item'>
                        <a href={typeof image === 'string' ? image : image.src} target='_blank'>
                            <Image src={image} alt={`${alt} (#${index + 1})`} />
                        </a>
                    </li>
                )
        )
    }
</ol>

<style>
    ol.gallery-list {
        display: flex;
        flex-wrap: wrap;
        flex-direction: row;

        justify-content: center;
        align-items: center;

        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1em;
        list-style: none;
        padding: 0;

        margin: 1em;
    }

    ol.gallery-list li.gallery-item {
        margin: 0;
        padding: 0;

        flex: 1 1 1;

        transform: scale(1);
        transition: all 0.1s ease-in-out;
    }

    ol.gallery-list li.gallery-item:hover {
        transform: scale(1.035);
    }

    ol.gallery-list img {
        display: block;
        width: 100%;
        height: auto;
        max-width: 25vw;
        max-height: 40vh;
        object-fit: cover;
        border-radius: 0.5em;
        border: 1px solid var(--wow-border);
    }
</style>
