---
import type { ImageMetadata } from 'astro'
import { Image as AstroImage } from 'astro:assets'

type Props = {
    src: ImageMetadata | string
    alt?: string
    style?: string
    class?: string
}

const { src, alt, style, class: className } = Astro.props
---

{typeof src === 'string'
    ? <img src={src} alt={alt || ''} style={style} class={className} />
    : <AstroImage src={src} alt={alt || ''} style={style} class={className} />
}
