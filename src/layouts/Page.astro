---
import type { ImageMetadata, MarkdownLayoutProps } from 'astro'

import Base from '@layouts/Base.astro'
import type { CollectionEntry } from 'astro:content'

type Props = MarkdownLayoutProps<{
	title: string
	blurb: string
	authors?: (string | CollectionEntry<'authors'>)[]
	dated?: Date
	image?: ImageMetadata | string
	reading?: { words: number; minutes: number }
}>

const { title, blurb, image, authors, dated, reading, ...rest } = Astro.props.frontmatter || Astro.props
---

<Base title={title} blurb={blurb} image={image} authors={authors} dated={dated} reading={reading} {...rest}>
	<slot />
</Base>
