---
import { type CollectionEntry, getCollection, getEntry, render } from 'astro:content'
import Post from '@layouts/Post.astro'
import StructuredData from '@components/StructuredData.astro'
import { readingStats } from '@format'

export async function getStaticPaths() {
	const posts = await getCollection('posts')
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post: post },
	}))
}

type Props = {
	post: CollectionEntry<'posts'>
}

const { post } = Astro.props
const {
	data: { dated, title, blurb, image, authors, ...rest },
} = post

// In Astro 6, references in collection data are bare strings (the IDs).
const authorEntries = (await Promise.all(authors.map((id) => getEntry('authors', id)))).filter(
	(e): e is CollectionEntry<'authors'> => e !== undefined,
)
const reading = readingStats(post.body ?? '')

const { Content } = await render(post)
---

<Post title={title} blurb={blurb} image={image} authors={authors} dated={dated} reading={reading} {...rest}>
	<StructuredData title={title} blurb={blurb} dated={dated} image={image} authors={authorEntries} />
	<Content />
</Post>
