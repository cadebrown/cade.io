---
import { type CollectionEntry, getCollection, getEntries, render } from 'astro:content'
import Post from '@layouts/Post.astro'
import StructuredData from '@components/StructuredData.astro'
import { readingStats } from '@format'

export async function getStaticPaths() {
	const posts = await getCollection('posts')
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post: post },
	}))
}

type Props = {
	post: CollectionEntry<'posts'>
}

const { post } = Astro.props
const {
	data: { dated, title, blurb, image, authors, ...rest },
} = post

const authorEntries = await getEntries(authors)
const reading = readingStats(post.body ?? '')

const { Content } = await render(post)
---

<Post title={title} blurb={blurb} image={image} authors={authors.map((author) => author.id)} dated={dated} reading={reading} {...rest}>
	<StructuredData title={title} blurb={blurb} dated={dated} image={image} authors={authorEntries} />
	<Content />
</Post>
